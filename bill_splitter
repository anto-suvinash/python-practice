running_total = 0

num_of_friends = int(input("Enter the number of friends splitting the bill: "))

appetizers = float(input("Enter the cost of appitizers : "))
main_courses = float(input("Enter the cost of Main Courses : "))
desserts = float(input("Enter the cost of Desserts : "))
drinks = float(input("Enter the  cost of Drinks  : "))

running_total += appetizers + main_courses + desserts + drinks
print('Total bill so far:', round(running_total, 2))

tip_percentage = float(input("Enter the tip percentage (e.g. 10 for 10%): "))
if tip_percentage < 0:
    raise ValueError("Tip percentage must be non-negative.")
tip = running_total * (tip_percentage / 100)
print("Tip amount:", tip)

running_total += tip
print('Total with tip:', round(running_total, 2))

final_bill = running_total / num_of_friends
print('Bill per person:', round(final_bill, 2))
